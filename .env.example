# ===========================================================================
#  Nexus v2 — Variables d'environnement
#
#  Architecture 100 % Supabase : il n'y a plus de backend local à configurer.
#  Les variables vivent à deux endroits :
#    - frontend/.env         → consommées par Vite (côté navigateur)
#    - Supabase Edge Secrets → consommées par les Edge Functions (côté serveur)
# ===========================================================================

#--- Frontend (voir frontend/.env.example) ---------------------------------
# La seule variable côté client : l'URL de base des Edge Functions.
# VITE_API_URL=https://VOTRE-PROJET.supabase.co/functions/v1

#--- Edge Functions (Dashboard Supabase → Edge Functions → Secrets) ---------
# Identité du projet (Dashboard → Project Settings → API).
# SUPABASE_URL=https://VOTRE-PROJET.supabase.co
# SUPABASE_ANON_KEY=eyJ...         (clé publique)
# SUPABASE_SERVICE_ROLE_KEY=eyJ... (secret — court-circuite la RLS, NE JAMAIS exposer côté client)

# Numéros de réception Mobile Money affichés aux joueurs (GET /payments/mobile-money).
# MOBILE_MONEY_HOLDER=Nexus Madagascar
# MVOLA_NUMBER=0384362216
# ORANGE_MONEY_NUMBER=0320000000
# AIRTEL_MONEY_NUMBER=0330000000

# Paramètres économiques.
# SHARE_VALUE=5000              # 1 part = 5000 Ar (doit matcher current_setting('app.share_value') côté SQL)
# PLATFORM_COMMISSION_RATE=10   # commission plateforme en %
