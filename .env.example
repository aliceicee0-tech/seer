# ==========================================================
#  Seer — exemple de configuration (.env)
#  Copiez ce fichier en .env puis adaptez les valeurs.
#  ⚠️  En production : DJANGO_DEBUG=False et une vraie SECRET_KEY.
# ==========================================================

# ---- Django ----
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Origines autorisées pour le CORS (frontend)
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Base de données PostgreSQL ----
# Soit DATABASE_URL complet, soit les variables individuelles ci-dessous.
DATABASE_URL=postgres://seer:seer@127.0.0.1:5432/seer
DB_NAME=seer
DB_USER=seer
DB_PASSWORD=seer
DB_HOST=127.0.0.1
DB_PORT=5432

# ---- Cache (optionnel, recommandé en prod) ----
# Vierge = LocMem (dev). En prod : Redis (Upstash free tier).
REDIS_URL=

# ---- Plateforme ----
# Commission plateforme en % (pari mutuel) — prélevée à la résolution.
PLATFORM_COMMISSION_RATE=10.0
# Mise minimale en MGA (= points)
MIN_BET_AMOUNT=500

# ---- Rate limiting (anti brute-force) ----
THROTTLE_ANON=120/min
THROTTLE_USER=300/min
THROTTLE_LOGIN=5/min

# ---- HTTPS (prod) ----
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=2592000

# ---- Numéros Mobile Money de réception (affichés aux joueurs) ----
MVOLA_NUMBER=0340000000
ORANGE_MONEY_NUMBER=0320000000
AIRTEL_MONEY_NUMBER=0330000000
# Nom du détenteur affiché (ex: "Seer Madagascar")
MOBILE_MONEY_HOLDER=Seer Madagascar
