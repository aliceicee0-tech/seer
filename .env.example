# ==========================================================
#  Nexus — exemple de configuration (.env)
#  Copiez ce fichier en .env puis adaptez les valeurs.
#  ⚠️  En production : DJANGO_DEBUG=False et une vraie SECRET_KEY.
# ==========================================================

# ---- Django ----
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Origines autorisées pour le CORS (frontend). En prod même-origin via Caddy,
# ces origines ne servent qu'en dev (Vite sur :5173).
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Base de données PostgreSQL ----
# Soit DATABASE_URL complet, soit les variables individuelles ci-dessous.
# ⚠️ SQLite est INTERDIT en production (DEBUG=False) : les verrous pessimistes
#    qui protègent l'argent réel y sont ignorés (voir settings.py — garde B4).
DATABASE_URL=postgres://seer:seer@127.0.0.1:5432/seer
DB_NAME=seer
DB_USER=seer
DB_PASSWORD=seer
DB_HOST=127.0.0.1
DB_PORT=5432

# ---- Cache (optionnel, recommandé en prod multi-instances) ----
# Vierge = LocMem (dev / mono-instance). En prod : Redis (Upstash free tier).
REDIS_URL=

# ---- Rate limiting (anti brute-force) ----
THROTTLE_ANON=120/min
THROTTLE_USER=300/min
THROTTLE_LOGIN=5/min

# ---- HTTPS (prod) ----
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=2592000   # 30 jours

# ---- Moteur Polymarket ----
# 1 part vaut SHARE_VALUE Ar (Ariary) à la résolution.
# Le prix d'une part sur le carnet fluctue entre MIN_ORDER_PRICE et MAX_ORDER_PRICE.
# prix YES + prix NON = SHARE_VALUE (toujours).
SHARE_VALUE=5000
MIN_ORDER_PRICE=1
MAX_ORDER_PRICE=4999

# ---- Plateforme ----
PLATFORM_COMMISSION_RATE=10.0   # % (réservé — non prélevé actuellement)
MIN_BET_AMOUNT=500              # Mise minimale en MGA

# ---- Numéros Mobile Money de réception (affichés aux joueurs) ----
MVOLA_NUMBER=0384362216
ORANGE_MONEY_NUMBER=0320000000
AIRTEL_MONEY_NUMBER=0330000000
# Nom du détenteur affiché (ex: "Nexus Madagascar")
MOBILE_MONEY_HOLDER=Nexus Madagascar
